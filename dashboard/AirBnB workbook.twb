            <mapsource name='Tableau' />
          </mapsources>
          <datasource-dependencies datasource='federated.145yd0z09dek1p122aieh1rym9jb'>
            <column caption='Occupancy' datatype='real' default-format='p0%' name='[Calculation_0862293855801345]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(365-[availability_365])/365' />
