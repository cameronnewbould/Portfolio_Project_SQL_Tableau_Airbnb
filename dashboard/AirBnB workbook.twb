      <column caption='Occupancy' datatype='real' default-format='p0%' name='[Calculation_0862293855801345]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(365-[availability_365])/365' />
      </column>
      <column caption='Occupancy Category' datatype='string' name='[Calculation_0862293856186370]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0862293855801345] &gt;= 0.75 THEN &quot;High Occupancy&quot;&#13;&#10;ELSEIF [Calculation_0862293855801345] &gt;= 0.40 THEN &quot;Moderate Occupancy&quot;&#13;&#10;ELSE &quot;Low Occupancy&quot;&#13;&#10;END' />
      </column>
      <column caption='Occupancy Bar' datatype='string' name='[Calculation_0862293856370691]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0862293855801345] &gt;= 0.9 THEN &quot;██████████&quot;&#13;&#10;ELSEIF [Calculation_0862293855801345] &gt;= 0.8 THEN &quot;█████████░&quot;&#13;&#10;ELSEIF [Calculation_0862293855801345] &gt;= 0.7 THEN &quot;████████░░&quot;&#13;&#10;ELSEIF [Calculation_0862293855801345] &gt;= 0.6 THEN &quot;███████░░░&quot;&#13;&#10;ELSEIF [Calculation_0862293855801345] &gt;= 0.5 THEN &quot;██████░░░░&quot;&#13;&#10;ELSEIF [Calculation_0862293855801345] &gt;= 0.4 THEN &quot;█████░░░░░&quot;&#13;&#10;ELSEIF [Calculation_0862293855801345] &gt;= 0.3 THEN &quot;████░░░░░░&quot;&#13;&#10;ELSEIF [Calculation_0862293855801345] &gt;= 0.2 THEN &quot;███░░░░░░░&quot;&#13;&#10;ELSEIF [Calculation_0862293855801345] &gt;= 0.1 THEN &quot;██░░░░░░░░&quot;&#13;&#10;ELSE &quot;█░░░░░░░░░&quot;&#13;&#10;END' />
      </column>
      <column caption='Borough Average Price' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[Calculation_0862293857136644]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [neighbourhood] : AVG([price]) }' />
      </column>
      <column caption='Price Difference' datatype='real' name='[Calculation_0862293857357829]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[price] - [Calculation_0862293857136644]' />
      </column>
      <column caption='Price Difference Label' datatype='string' name='[Calculation_0862293857517574]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [price] &gt; [Calculation_0862293857136644] THEN&#13;&#10;&quot;Above Neighborhood Average&quot;&#13;&#10;ELSE&#13;&#10;&quot;Below Neighborhood Average&quot;&#13;&#10;END' />
      </column>
      <column caption='Availability' datatype='string' name='[Calculation_22804734207053824]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [availability_365] = 365 THEN &quot;Available All Year&quot;&#13;&#10;ELSE &quot;Limited Availability&quot;&#13;&#10;END' />
      </column>
      <column caption='Price Bucket' datatype='string' name='[Calculation_22804734207377409]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [price] &lt; 100 THEN &quot;&lt; $100&quot;&#13;&#10;ELSEIF [price] &lt; 200 THEN &quot;$100 - $199&quot;&#13;&#10;ELSEIF [price] &lt; 300 THEN &quot;$200 - $299&quot;&#13;&#10;ELSE &quot;$300+&quot;&#13;&#10;END' />
      </column>
